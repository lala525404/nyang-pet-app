{
  "name": "choeae-app",
  "version": "1.0.0",
  "description": "최애를 풀어놨습니다 - Desktop Buddy App",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist:win": "npm run build && electron-builder --win --dir",
    "dist:mac": "npm run build && electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.choeae.app",
    "productName": "choeae-app",
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png",
      "category": "public.app-category.entertainment"
    },
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "nsis": {
      "shortcutName": "최애를 풀어놨습니다"
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0"
  }
}